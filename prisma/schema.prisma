generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  USER
}

enum ProductStatus {
  DRAFT
  ACTIVE
  SOLD
  ARCHIVED
}

enum PaymentMode {
  AUTOMATIC
  ZALO
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String?
  displayName  String?
  role         Role        @default(USER)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  carts        Cart[]
  orders       Order[]
}

model Product {
  id               String        @id @default(cuid())
  code             String        @unique
  slug             String        @unique
  title            String
  tag              String
  tier             String
  tierClass        String?
  price            String
  priceValue       Int
  summary          String        @db.Text
  shortDescription String
  descriptionHtml  String        @db.Text
  skinXe           String        @default("")
  thanhGiap        String        @default("")
  doBAPE           String        @default("")
  accountLoginEmail String?
  accountLoginPassword String?
  paymentMode      PaymentMode   @default(AUTOMATIC)
  isFeaturedHero   Boolean       @default(false)
  featuredWeekRank Int?
  status           ProductStatus @default(ACTIVE)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  images           ProductImage[]
  cartItems        CartItem[]

  @@index([isFeaturedHero])
  @@index([featuredWeekRank])
}

model AccountType {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  className String   @default("tier-starter")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductImage {
  id         String   @id @default(cuid())
  productId  String
  imageUrl   String
  alt        String?
  position   Int      @default(0)
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, position])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
}

model CartItem {
  id         String   @id @default(cuid())
  cartId     String
  productId  String
  quantity   Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  cart       Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
}

model Order {
  id         String      @id @default(cuid())
  userId     String
  paymentOrderCode String?   @unique
  paymentLinkId String?
  checkoutUrl String?
  paymentProvider String?    @default("payos")
  totalLabel String
  totalValue Int
  status     String      @default("pending")
  paidAt     DateTime?
  deliveryEmailLockedAt DateTime?
  deliveryEmailSentAt DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items      OrderItem[]

  @@index([userId, createdAt])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  productId  String?
  productSlug String?
  title      String
  imageUrl   String?
  priceLabel String
  priceValue Int
  accountLoginEmail String?
  accountLoginPassword String?
  quantity   Int      @default(1)
  createdAt  DateTime @default(now())
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}
